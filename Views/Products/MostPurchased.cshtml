@model IEnumerable<NorthwindApp.Models.ViewModels.MostPurchasedViewModel>

@{
    ViewData["Title"] = "Productos más comprados";
}

<h1>🏆 Productos más comprados</h1>
<hr />
<p>Top 10 productos con mayor cantidad de ventas.</p>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>#</th>
                <th>Producto</th>
                <th>Categoría</th>
                <th>Proveedor</th>
                <th class="text-end">Precio</th>
                <th class="text-center">Stock</th>
                <th class="text-center">Cantidad vendida</th>
                <th class="text-end">Ingresos totales</th>
            </tr>
        </thead>
        <tbody>
            @{
                int counter = 1;
            }
            @foreach (var item in Model)
            {
                <tr>
                    <td>@counter</td>
                    <td>@item.ProductName</td>
                    <td>@item.Category?.CategoryName</td>
                    <td>@item.Supplier?.CompanyName</td>
                    <td class="text-end">@item.UnitPrice.ToString("C")</td>
                    <td class="text-center">
                        @if (item.UnitsInStock > 10)
                        {
                            <span class="badge bg-success">@item.UnitsInStock</span>
                        }
                        else if (item.UnitsInStock > 0)
                        {
                            <span class="badge bg-warning">@item.UnitsInStock</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">0</span>
                        }
                    </td>
                    <td class="text-center">
                        <span class="badge bg-primary">@item.TotalQuantitySold</span>
                    </td>
                    <td class="text-end fw-bold">@item.TotalRevenue.ToString("C")</td>
                </tr>
                counter++;
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center">
        No hay datos de ventas disponibles.
    </div>
}

<div class="mt-3">
    <a asp-action="Admin" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Volver
    </a>
</div>
