@model IEnumerable<NorthwindApp.Models.Product>

@{
    ViewData["Title"] = "Productos discontinuados";
}

<h1>⛔ Productos discontinuados</h1>
<hr />
<p>Productos que han sido marcados como discontinuados.</p>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Producto</th>
                <th>Categoría</th>
                <th class="text-end">Precio</th>
                <th class="text-center">Stock</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ProductName</td>
                    <td>@item.Category?.CategoryName</td>
                    <td class="text-end">@item.UnitPrice?.ToString("C")</td>
                    <td class="text-center">@item.UnitsInStock</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-success text-center">
        <i class="fas fa-check-circle"></i> No hay productos discontinuados.
    </div>
}

<div class="mt-3">
    <a asp-action="Admin" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Volver
    </a>
</div>