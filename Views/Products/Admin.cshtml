@model IEnumerable<NorthwindApp.Models.Product>

@{
    ViewData["Title"] = "Administración de productos";
}

<h1>📦 Administración de productos</h1>
<hr />

<div class="row mb-3">
    <div class="col-md-6">
        <form asp-action="Admin" method="get" class="d-flex">
            <input type="text" name="searchString" class="form-control" 
                   placeholder="Buscar producto..." />
            <button type="submit" class="btn btn-primary ms-2">Buscar</button>
        </form>
    </div>
    <div class="col-md-6 text-end">
        <a asp-action="Create" class="btn btn-success">
            <i class="fas fa-plus"></i> Nuevo producto
        </a>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Producto</th>
                <th>Categoría</th>
                <th>Proveedor</th>
                <th class="text-end">Precio</th>
                <th class="text-center">Stock</th>
                <th class="text-center">Estado</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ProductName</td>
                    <td>@item.Category?.CategoryName</td>
                    <td>@item.Supplier?.CompanyName</td>
                    <td class="text-end">@item.UnitPrice?.ToString("C")</td>
                    <td class="text-center">
                        @if (item.UnitsInStock > 10)
                        {
                            <span class="badge bg-success">@item.UnitsInStock</span>
                        }
                        else if (item.UnitsInStock > 0)
                        {
                            <span class="badge bg-warning">@item.UnitsInStock</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">0</span>
                        }
                    </td>
                    <td class="text-center">
                        @if (item.Discontinued == 0)
                        {
                            <span class="badge bg-success">Disponible</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Discontinuado</span>
                        }
                    </td>
                    <td class="text-center">
                        <a asp-action="ManageStock" asp-route-id="@item.ProductId" 
                           class="btn btn-warning btn-sm">
                            <i class="fas fa-cubes"></i>
                        </a>
                        <a asp-action="Edit" asp-route-id="@item.ProductId" 
                           class="btn btn-primary btn-sm">
                            <i class="fas fa-edit"></i>
                        </a>
                        <a asp-action="Details" asp-route-id="@item.ProductId" 
                           class="btn btn-info btn-sm">
                            <i class="fas fa-info-circle"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.ProductId" 
                           class="btn btn-danger btn-sm">
                            <i class="fas fa-trash"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center">
        No hay productos registrados.
    </div>
}
