@model IEnumerable<NorthwindApp.Models.Product>

@{
    ViewData["Title"] = "Productos sin stock";
}

<h1>🚫 Productos sin stock</h1>
<hr />
<p>Productos con stock igual a 0 unidades.</p>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Producto</th>
                <th>Categoría</th>
                <th class="text-end">Precio</th>
                <th class="text-center">Stock</th>
                <th class="text-center">Acción</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ProductName</td>
                    <td>@item.Category?.CategoryName</td>
                    <td class="text-end">@item.UnitPrice?.ToString("C")</td>
                    <td class="text-center">
                        <span class="badge bg-danger">0</span>
                    </td>
                    <td class="text-center">
                        <a asp-action="ManageStock" asp-route-id="@item.ProductId" 
                           class="btn btn-warning btn-sm">
                            <i class="fas fa-cubes"></i> Gestionar
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-success text-center">
        <i class="fas fa-check-circle"></i> No hay productos sin stock.
    </div>
}

<div class="mt-3">
    <a asp-action="Admin" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Volver
    </a>
</div>