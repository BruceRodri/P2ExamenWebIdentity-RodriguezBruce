@model IEnumerable<NorthwindApp.Models.Order>

@{
    ViewData["Title"] = "Mis órdenes";
}

<h1>📋 Mis órdenes</h1>
<hr />

@if (TempData["Info"] != null)
{
    <div class="alert alert-info">
        @TempData["Info"]
    </div>
}

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th># Orden</th>
                <th>Fecha</th>
                <th>Productos</th>
                <th class="text-end">Total</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                var total = item.OrderDetails?.Sum(od => od.UnitPrice * od.Quantity) ?? 0;
                <tr>
                    <td>#@item.OrderId</td>
                    <td>@item.OrderDate?.ToString("dd/MM/yyyy HH:mm")</td>
                    <td class="text-center">@item.OrderDetails?.Count</td>
                    <td class="text-end fw-bold">@total.ToString("C")</td>
                    <td class="text-center">
                        <a asp-action="Details" asp-route-id="@item.OrderId" 
                           class="btn btn-info btn-sm">
                            <i class="fas fa-eye"></i> Ver
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center">
        No tienes órdenes registradas.
    </div>
}

<div class="mt-3">
    <a asp-action="Available" asp-controller="Products" class="btn btn-primary">
        <i class="fas fa-store"></i> Seguir comprando
    </a>
</div>